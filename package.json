{
    "name": "mesob-telegram-bot",
    "version": "2.0.0",
    "description": "Enhanced multilingual Telegram bot for MESOB Shashemene government services",
    "main": "bot.js",
    "scripts": {
        "start": "node bot.js",
        "start:enhanced": "node bot-enhanced.js",
        "start:production": "NODE_ENV=production node bot-enhanced.js",
        "dev": "nodemon bot.js",
        "dev:enhanced": "nodemon bot-enhanced.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint . --ext .js",
        "lint:fix": "eslint . --ext .js --fix",
        "backup": "node scripts/backup.js",
        "health-check": "node scripts/health-check.js"
    },
    "dependencies": {
        "axios": "^1.6.2",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "node-telegram-bot-api": "^0.66.0",
        "pino": "^8.17.2",
        "redis": "^4.6.11",
        "telegraf": "^4.16.3",
        "uuid": "^9.0.1",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "supertest": "^6.3.3"
